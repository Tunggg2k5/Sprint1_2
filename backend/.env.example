PORT=4100
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/das?retryWrites=true&w=majority&appName=Cluster0
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5174

# Email OTP reset password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="SmileCare <your-email@gmail.com>"
SMTP_SECURE=false
PASSWORD_RESET_OTP_TTL_MINUTES=10

# Development only: return OTP in API response when SMTP is not configured.
MAIL_DEV_RETURN_OTP=false
